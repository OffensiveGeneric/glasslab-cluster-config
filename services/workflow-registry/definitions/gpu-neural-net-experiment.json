{
  "workflow_id": "gpu-neural-net-experiment",
  "display_name": "GPU Neural Net Experiment",
  "workflow_family": "gpu-neural-net-experiment",
  "description": "Run a bounded neural network experiment on a GPU worker with an explicit dataset, model-family, and training-note contract.",
  "required_inputs": [
    {
      "name": "dataset_uri",
      "input_type": "dataset",
      "required": true,
      "description": "Resolved dataset location for the neural-net experiment."
    },
    {
      "name": "model_family",
      "input_type": "parameter_set",
      "required": true,
      "description": "Named model family or architecture template to train."
    },
    {
      "name": "training_notes",
      "input_type": "notes",
      "required": true,
      "description": "Bounded notes describing the experimental goal and training constraints."
    }
  ],
  "allowed_models": [
    "pytorch-template-v1",
    "lightning-template-v1",
    "deterministic-template"
  ],
  "runner_image": "ghcr.io/offensivegeneric/glasslab-gpu-neural-runner:0.1.0",
  "evaluator_type": "gpu-training-metrics",
  "expected_artifacts": {
    "required": [
      "run_manifest.json",
      "config.json",
      "metrics.json",
      "artifacts_index.json",
      "report.md",
      "status.json",
      "logs/"
    ],
    "optional": [
      "analysis_notebook.ipynb",
      "checkpoint_manifest.json",
      "model_card.md"
    ]
  },
  "resource_profile": {
    "profile_name": "gpu-small",
    "requests": {
      "cpu": "2",
      "memory": "4Gi",
      "nvidia.com/gpu": "1"
    },
    "limits": {
      "cpu": "4",
      "memory": "8Gi",
      "nvidia.com/gpu": "1"
    },
    "node_selector": {
      "glasslab.io/gpu-candidate": "true",
      "glasslab.io/gpu-vendor": "nvidia"
    }
  },
  "approval_tier": "tier-2-approved-execution",
  "execution_status": "ready",
  "submission_backend": "kubernetes",
  "execution_blockers": [],
  "runtime_requirements": {
    "gpu": true,
    "training_stack": ["pytorch"],
    "purpose": "bounded neural-net experiment"
  }
}
