{
  "workflow_id": "metric-search-v0",
  "display_name": "Metric Search v0",
  "workflow_family": "generic-experiment",
  "description": "Run a bounded one-GPU metric-learning search workload from a config-driven image under the generic experiment contract. Supports contrastive learning for unseen class generalization via CIFAR-100 seen/unseen splits.",
  "required_inputs": [
    {
      "name": "dataset_bindings",
      "input_type": "artifact_bundle",
      "required": true,
      "description": "Resolved dataset bindings for the config-driven metric-search workload."
    },
    {
      "name": "pipeline",
      "input_type": "parameter_set",
      "required": false,
      "description": "Pipeline type: 'contrastive_learning' for unseen class generalization, 'standard_metric' for standard metric learning."
    }
  ],
  "allowed_models": [
    "config-driven"
  ],
  "runner_image": "ghcr.io/offensivegeneric/glasslab-gpu-experiment-runner:0.1.7-local",
  "evaluator_type": "art-retrieval-v1",
  "expected_artifacts": {
    "required": [
      "run_manifest.json",
      "config.json",
      "metrics.json",
      "artifacts_index.json",
      "report.md",
      "status.json",
      "logs/"
    ],
    "optional": [
      "comparison.json",
      "summary.md",
      "analysis_notebook.ipynb",
      "checkpoint_manifest.json",
      "embeddings/",
      "plots/"
    ]
  },
  "resource_profile": {
    "profile_name": "gpu-small",
    "requests": {
      "cpu": "2",
      "memory": "4Gi",
      "nvidia.com/gpu": "1"
    },
    "limits": {
      "cpu": "4",
      "memory": "8Gi",
      "nvidia.com/gpu": "1"
    },
    "node_selector": {
      "glasslab.io/gpu-candidate": "true",
      "glasslab.io/gpu-vendor": "nvidia"
    }
  },
  "approval_tier": "tier-2-approved-execution",
  "execution_status": "ready",
  "submission_backend": "kubernetes",
  "execution_blockers": [],
  "runtime_requirements": {
    "gpu": true,
    "training_stack": ["pytorch", "pytorch-metric-learning", "faiss", "umap"],
    "required_python_packages": ["torch", "pyyaml", "pytorch-metric-learning", "faiss-cpu", "umap-learn", "mlxtend", "torchcp", "optuna"],
    "modalities": ["computer_vision"],
    "dataset_layouts": ["manifest", "artifact-bundle", "imagefolder"],
    "purpose": "config-driven metric-learning search workload with contrastive learning support for unseen class generalization"
  },
  "pipeline_support": {
    "contrastive_learning": {
      "description": "Contrastive representation learning for unseen class generalization on CIFAR-100",
      "loss_functions": ["supervised_contrastive", "triplet", "n-pair", "multi-similarity"],
      "mining_strategies": ["random", "hard_negative", "semi_hard_negative"],
      "augmentations": ["random_resized_crop", "color_jitter", "random_horizontal_flip"],
      "evaluation_metrics": ["grouped_recall_at_k", "opis", "ami", "ari", "nmi", "silhouette"],
      "statistical_tests": ["5x2cv_paired_ttest", "mcnemar"],
      "hpo_strategies": ["random_search", "bayesian_optimization", "asha"]
    },
    "standard_metric": {
      "description": "Standard metric learning with basic loss functions",
      "loss_functions": ["contrastive", "triplet"],
      "mining_strategies": ["random"],
      "augmentations": ["basic"],
      "evaluation_metrics": ["recall_at_k", "precision_at_k", "accuracy"],
      "hpo_strategies": ["grid_search", "random_search"]
    }
  },
  "experiment_type": "gpu-training-job",
  "workload_id": "metric-search-v0",
  "schema_ref": "glasslab-metric-search RunSpec v0",
  "default_entrypoint": [
    "sh",
    "-lc",
    "python3 scripts/run_experiment.py --config configs/search_spaces/art_metric_baseline.yaml --output-dir /mnt/artifacts/$GLASSLAB_RUNNER_EXPERIMENT_ID"
  ],
  "allow_custom_image": true,
  "allow_custom_entrypoint": true,
  "metric_contract": {
    "primary_metric": "composite_score",
    "higher_is_better": true
  }
}
