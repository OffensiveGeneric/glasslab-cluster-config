#!ipxe
set server http://192.168.1.44

# Installed worker node should prefer local disk.
iseq ${mac} 90:b1:1c:90:22:50 && goto localboot48 ||
iseq ${ip} 192.168.1.48 && goto localboot48 ||
iseq ${net0/mac} 90:b1:1c:90:22:50 && goto localboot48 ||
iseq ${net0/ip} 192.168.1.48 && goto localboot48 ||

# Newly discovered worker should prefer local disk after its first install.
iseq ${mac} 90:b1:1c:90:ad:18 && goto localboot02 ||
iseq ${ip} 192.168.1.11 && goto localboot02 ||
iseq ${net0/mac} 90:b1:1c:90:ad:18 && goto localboot02 ||
iseq ${net0/ip} 192.168.1.11 && goto localboot02 ||

# Control-plane candidate should also try local disk first after its first install.
iseq ${mac} 18:66:da:23:44:38 && goto localboot49 ||
iseq ${ip} 192.168.1.49 && goto localboot49 ||
iseq ${net0/mac} 18:66:da:23:44:38 && goto localboot49 ||
iseq ${net0/ip} 192.168.1.49 && goto localboot49 ||

# New worker node03 should prefer local disk after its first install.
iseq ${mac} 18:66:da:23:12:05 && goto localboot03 ||
iseq ${ip} 192.168.1.50 && goto localboot03 ||
iseq ${net0/mac} 18:66:da:23:12:05 && goto localboot03 ||
iseq ${net0/ip} 192.168.1.50 && goto localboot03 ||

# New worker node04 should prefer local disk after its first install.
iseq ${mac} 18:66:da:24:44:de && goto localboot04 ||
iseq ${ip} 192.168.1.51 && goto localboot04 ||
iseq ${net0/mac} 18:66:da:24:44:de && goto localboot04 ||
iseq ${net0/ip} 192.168.1.51 && goto localboot04 ||

# New worker node05 should prefer local disk after its first install.
iseq ${mac} 34:17:eb:a3:e6:c1 && goto localboot05 ||
iseq ${ip} 192.168.1.47 && goto localboot05 ||
iseq ${net0/mac} 34:17:eb:a3:e6:c1 && goto localboot05 ||
iseq ${net0/ip} 192.168.1.47 && goto localboot05 ||

goto install_default

:localboot48
sanboot --no-describe --drive 0x80 || goto install48

:localboot49
sanboot --no-describe --drive 0x80 || goto install49

:localboot02
sanboot --no-describe --drive 0x80 || goto install02

:localboot03
sanboot --no-describe --drive 0x80 || goto install03

:localboot04
sanboot --no-describe --drive 0x80 || goto install04

:localboot05
sanboot --no-describe --drive 0x80 || goto install05

:install48
echo Installing node48 profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/node48/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:install49
echo Installing cp01 profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/node49/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:install02
echo Installing node02 profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/node02/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:install03
echo Installing node03 profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/node03/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:install04
echo Installing node04 profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/node04/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:install05
echo Installing node05 profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/node05/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:install_default
echo Installing default profile
kernel ${server}/k/vmlinuz ip=dhcp boot=casper --- url=${server}/u.iso autoinstall ds=nocloud-net;s=${server}/c/default/ || goto debug
initrd ${server}/k/initrd || goto debug
boot || goto debug

:debug
echo PXE install path failed; dropping to shell
shell
